{
  "name": "pyrce-high",
  "version": "0.0.0",
  "private": true,
  "description": "Pyrce High — TypeScript / Nakama / Phaser 4 rewrite of the BYOND game",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm -F @pyrce/server dev",
    "dev:client": "pnpm -F @pyrce/client dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm -r --parallel run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "typescript": "^5.7.0"
  }
}
