{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2017"],
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": false,
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "verbatimModuleSyntax": false,
    "typeRoots": ["./node_modules", "../../node_modules"],
    "types": ["nakama-runtime"]
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../shared" }]
}
