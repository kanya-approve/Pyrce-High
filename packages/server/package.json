{
  "name": "@pyrce/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pyrce High Nakama TypeScript runtime modules (bundled to a single dist/index.js for Goja)",
  "scripts": {
    "dev": "rollup -c --watch",
    "build": "rollup -c",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pyrce/shared": "workspace:*"
  },
  "devDependencies": {
    "nakama-runtime": "github:heroiclabs/nakama-common",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "rollup": "^4.27.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  }
}
