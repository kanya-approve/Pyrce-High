{
  "name": "@pyrce/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pyrce High Nakama TypeScript runtime modules (bundled to a single dist/index.js for Goja)",
  "scripts": {
    "dev": "rollup -c --watch",
    "build": "rollup -c",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pyrce/shared": "workspace:*"
  },
  "devDependencies": {
    "nakama-runtime": "github:heroiclabs/nakama-common#v1.45.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.0"
  }
}
