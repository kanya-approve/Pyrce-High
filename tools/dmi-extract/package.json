{
  "name": "@pyrce/dmi-extract",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "One-shot tool: parse BYOND .dmi files and pack into a Phaser texture atlas. Throwaway once art pipeline is finalised.",
  "scripts": {
    "build": "tsc -b",
    "extract": "node dist/cli.js",
    "extract:all": "node dist/cli.js ../../assets/dmi-source ../../packages/client/public/atlases",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  }
}
